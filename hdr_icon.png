<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 420 110" width="420" height="110" role="img" aria-label="Vector Grid">
  <defs>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&amp;family=JetBrains+Mono:wght@500&amp;display=swap');
      .wm  { font-family: 'Fraunces','DejaVu Serif',Georgia,serif; font-weight:700; }
      .tag { font-family: 'JetBrains Mono',monospace; font-weight:500; letter-spacing:.22em; }
    </style>
  </defs>
  <g transform="translate(20,23)">
    <rect width="64" height="64" rx="15" fill="#1A1612"/>
    <g transform="translate(34,31) rotate(-26) scale(0.92) translate(-16,0)">
      <g fill="#27B3A3"><circle cx="-6" cy="2" r="2.3"/><circle cx="-12" cy="4" r="1.7"/><circle cx="-18" cy="6" r="1.2"/></g>
      <path d="M46,0 L0,15 L15,2 Z" fill="#C2600A"/>
      <path d="M46,0 L0,-15 L15,2 Z" fill="#F3A23E"/>
      <path d="M46,0 L15,2" stroke="#FBF1E2" stroke-width="1.4" opacity="0.5"/>
    </g>
  </g>
  <text class="wm" x="104" y="56" font-size="42" fill="#1A1612">Vector<tspan fill="#C96A00"> Grid</tspan></text>
  <text class="tag" x="106" y="80" font-size="10.5" fill="#9A9085">SHIPS&#160;PAN-INDIA</text>
</svg>
